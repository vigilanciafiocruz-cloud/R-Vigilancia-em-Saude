2 - Construção de um prompt para buscar e esclarecer erros em um script R
detectar_erro <- function(codigo_texto)
 {
  tryCatch(
    {
      # Executa o código passado como texto
      resultado <- eval(parse(text = codigo_texto))
      cat("\n✅ Código executado com sucesso!\n")
      print(resultado)
    },
    error = function(e) {
      # Mostra a mensagem de erro
      cat("\n⚠️ Erro detectado:\n")
      cat(e$message, "\n\n")
    }
  )
}
detectar_erro("library(pacote_que_nao_existe)")

